{
  "name": "kemping-drive",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "vite --host 0.0.0.0 --port 5180",
    "dev:backend": "npm run db:migrate && tsx watch server/src/index.ts",
    "db:migrate": "tsx server/src/migrate.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "tsc --noEmit -p tsconfig.app.json && vite build",
    "build:backend": "tsc -p tsconfig.server.json",
    "test:backend": "tsx --test server/test/*.test.ts",
    "test:backend:coverage": "node --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=65 --import tsx --test server/test/*.test.ts",
    "test:backend:integration": "tsx server/test/api.integration.ts",
    "test:backend:integration:coverage": "c8 --all --src=server/src --exclude=server/test/** --exclude=server/src/index.ts --exclude=server/src/migrate.ts --exclude=server/src/create-administrator.ts --exclude=server/src/provision-runtime-role.ts --exclude=server/src/validate-production-data.ts --reporter=text --check-coverage --lines=75 --functions=70 --branches=60 tsx server/test/api.integration.ts",
    "test:backend:migrations": "tsx server/test/migrations.integration.ts",
    "test:contracts": "tsx --test server/test/contracts.test.ts",
    "test:e2e": "playwright test",
    "test:stage9": "node scripts/run-stage9-tests.mjs",
    "lint": "eslint . --max-warnings=0",
    "audit:dependencies": "npm audit --audit-level=high",
    "admin:create": "tsx server/src/create-administrator.ts",
    "start:backend": "node server/dist/index.js",
    "preview": "vite preview --host 0.0.0.0 --port 5180"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "c8": "^12.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.7.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.0.7"
  }
}
