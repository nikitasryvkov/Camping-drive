# Public site and Docker images
SITE_DOMAIN=camping.drivebro.ru
PUBLIC_SITE_URL=https://camping.drivebro.ru
VITE_SITE_URL=https://camping.drivebro.ru
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
IMAGE_TAG=2026.07.22-1
# Full SHA of the exact clean commit that passed CI.
RELEASE_COMMIT=
# Fill only after the locked build prints the approved release-manifest SHA-256.
RELEASE_MANIFEST_SHA256=

# PostgreSQL. Both independent passwords are required in the protected .env.local.
POSTGRES_DB=camping_drive
POSTGRES_USER=camping_drive
POSTGRES_PASSWORD=
APP_DB_USER=camping_drive_app
APP_DB_PASSWORD=
PUBLIC_ORIGINS=https://camping.drivebro.ru

# Host ports
FRONTEND_PORT=8080
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# Local backend development (Docker Compose overrides host and uploads path)
PORT=3000
PGHOST=127.0.0.1
PGPORT=5432
UPLOADS_DIR=./uploads
IMAGE_MAX_UPLOAD_MB=15
IMAGE_MAX_INPUT_MEGAPIXELS=40
IMAGE_PROCESSING_CONCURRENCY=1
ADMIN_SESSION_TTL_HOURS=12
PASSWORD_VERIFICATION_CONCURRENCY=1

# One-time administrator creation (do not store real values in this file):
# ADMIN_LOGIN=your-login ADMIN_PASSWORD=your-long-random-password npm run admin:create
